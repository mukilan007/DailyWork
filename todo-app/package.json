{
  "name": "tasks-app",
  "private": true,
  "version": "0.1.0",
  "description": "Tiny todo app — static frontend + Supabase backend.",
  "type": "module",
  "scripts": {
    "dev": "npx --yes serve . -l 5173",
    "db:link": "supabase link --project-ref %SUPABASE_PROJECT_REF%",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff --linked",
    "db:reset": "supabase db reset --linked",
    "db:new": "supabase migration new"
  },
  "devDependencies": {
    "supabase": "^1.200.3"
  }
}
